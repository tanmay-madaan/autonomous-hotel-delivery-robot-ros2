<?xml version="1.0"?>
<robot name="diff_drive_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ═══════════════════════════════════════════════════════════
       MATERIALS
  ═══════════════════════════════════════════════════════════ -->
  <material name="blue">
    <color rgba="0.2 0.4 0.8 1.0"/>
  </material>
  <material name="dark_grey">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="grey">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.05 0.05 0.05 1.0"/>
  </material>
  <material name="red">
    <color rgba="0.8 0.1 0.1 1.0"/>
  </material>

  <!-- ═══════════════════════════════════════════════════════════
       BASE FOOTPRINT
  ═══════════════════════════════════════════════════════════ -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 0.08" rpy="0 0 0"/>
  </joint>

  <!-- ═══════════════════════════════════════════════════════════
       BASE LINK  (chassis 0.5 × 0.3 × 0.15 m)
       mass = 5 kg   →  Ixx=(m/12)(y²+z²), etc.
  ═══════════════════════════════════════════════════════════ -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.5 0.3 0.15"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.5 0.3 0.15"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="5.0"/>
      <!-- Ixx = (m/12)*(y^2+z^2) = (5/12)*(0.09+0.0225) = 0.046875 -->
      <!-- Iyy = (m/12)*(x^2+z^2) = (5/12)*(0.25+0.0225) = 0.113542 -->
      <!-- Izz = (m/12)*(x^2+y^2) = (5/12)*(0.25+0.09)   = 0.141667 -->
      <inertia ixx="0.046875" ixy="0.0" ixz="0.0"
                               iyy="0.113542" iyz="0.0"
                                              izz="0.141667"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════════
       LEFT WHEEL
       radius=0.08 m  length=0.05 m  mass=0.5 kg
       Ixx=Iyy=(m/12)*(3r²+h²)   Izz=(m/2)*r²
  ═══════════════════════════════════════════════════════════ -->
  <link name="left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.05"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.05"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.5"/>
      <!-- Ixx=Iyy=(0.5/12)*(3*0.0064+0.0025)=0.5/12*0.0217=0.000904 -->
      <!-- Izz=(0.5/2)*0.0064=0.0016 -->
      <inertia ixx="0.000904" ixy="0.0" ixz="0.0"
                               iyy="0.000904" iyz="0.0"
                                              izz="0.001600"/>
    </inertial>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="left_wheel"/>
    <!-- y = +(chassis_width/2 + wheel_length/2) = 0.15+0.025 = 0.175 -->
    <origin xyz="0.0 0.175 -0.03" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.1" friction="0.1"/>
    <limit effort="10.0" velocity="5.0"/>
  </joint>

  <!-- ═══════════════════════════════════════════════════════════
       RIGHT WHEEL
  ═══════════════════════════════════════════════════════════ -->
  <link name="right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.05"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.05"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.000904" ixy="0.0" ixz="0.0"
                               iyy="0.000904" iyz="0.0"
                                              izz="0.001600"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="right_wheel"/>
    <origin xyz="0.0 -0.175 -0.03" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.1" friction="0.1"/>
    <limit effort="10.0" velocity="5.0"/>
  </joint>

  <!-- ═══════════════════════════════════════════════════════════
       CASTER WHEEL  (front, sphere r=0.04 m, mass=0.2 kg)
       Ixx=Iyy=Izz=(2/5)*m*r² = 0.4*0.2*0.0016 = 0.000128
  ═══════════════════════════════════════════════════════════ -->
  <link name="caster_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.04"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.000128" ixy="0.0" ixz="0.0"
                               iyy="0.000128" iyz="0.0"
                                              izz="0.000128"/>
    </inertial>
  </link>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="caster_link"/>
    <!-- placed at front-bottom of chassis -->
    <origin xyz="0.21 0.0 -0.075" rpy="0 0 0"/>
  </joint>

  <!-- ═══════════════════════════════════════════════════════════
       LASER LINK  (mounted at front-top of chassis)
       mass=0.1 kg, small box 0.05×0.05×0.05 m
  ═══════════════════════════════════════════════════════════ -->
  <link name="laser_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.05"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.05"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <!-- Ixx=Iyy=Izz=(0.1/12)*(0.05^2+0.05^2)=0.1/12*0.005=0.0000417 -->
      <inertia ixx="0.0000417" ixy="0.0" ixz="0.0"
                                iyy="0.0000417" iyz="0.0"
                                               izz="0.0000417"/>
    </inertial>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="laser_link"/>
    <!-- front face of chassis x=0.25, on top z=0.075+0.025=0.10 -->
    <origin xyz="0.20 0.0 0.10" rpy="0 0 0"/>
  </joint>

  <!-- ═══════════════════════════════════════════════════════════
       ROS2 CONTROL
  ═══════════════════════════════════════════════════════════ -->
  <ros2_control name="diff_drive_system" type="system">

    <hardware>
      <!-- Use GazeboSystem for Gazebo Harmonic / gz-sim -->
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>

    <!-- Left wheel -->
    <joint name="left_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-5</param>
        <param name="max">5</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <!-- Right wheel -->
    <joint name="right_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-5</param>
        <param name="max">5</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

  </ros2_control>

  <!-- ═══════════════════════════════════════════════════════════
       GAZEBO HARMONIC PLUGINS
  ═══════════════════════════════════════════════════════════ -->
  <gazebo>

    <!-- gz_ros2_control plugin -->
    <plugin filename="gz_ros2_control-system"
            name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find hotel_launch)/config/ros2_controllers.yaml</parameters>
      <ros>
        <remapping>~/cmd_vel:=cmd_vel</remapping>
      </ros>
    </plugin>


  </gazebo>

  <!-- ═══════════════════════════════════════════════════════════
       GAZEBO MATERIAL OVERRIDES
  ═══════════════════════════════════════════════════════════ -->
  <gazebo reference="base_link">
    <material>Gazebo/Blue</material>
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
  </gazebo>

  <gazebo reference="left_wheel">
    <material>Gazebo/DarkGrey</material>
    <mu1>0.9</mu1>
    <mu2>0.9</mu2>
  </gazebo>

  <gazebo reference="right_wheel">
    <material>Gazebo/DarkGrey</material>
    <mu1>0.9</mu1>
    <mu2>0.9</mu2>
  </gazebo>

  <gazebo reference="caster_link">
    <material>Gazebo/Grey</material>
    <!-- Low friction for passive caster -->
    <mu1>0.01</mu1>
    <mu2>0.01</mu2>
  </gazebo>

  <gazebo reference="laser_link">
    <sensor name="lidar_sensor" type="gpu_lidar">
      <topic>scan</topic>
      <update_rate>10</update_rate>
      <always_on>true</always_on>
      <visualize>true</visualize>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
          <vertical>
            <samples>1</samples>
            <resolution>1</resolution>
            <min_angle>0</min_angle>
            <max_angle>0</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.12</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <gz_frame_id>laser_link</gz_frame_id>
    </sensor>
  </gazebo>

</robot>
